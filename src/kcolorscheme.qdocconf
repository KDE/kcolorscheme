include($KDE_DOCS/global/qt-module-defaults-online.qdocconf)

project = KColorScheme
description = Classes to interact with KColorScheme.

documentationinheaders = true

headerdirs = .

headers.fileextensions = "*.qdoc *.h"

outputformats = HTML

depends += \
    qtcore \
    qtgui \
    qtwidgets \
    kconfig \
    kguiaddons \
    kconfigwidgets
